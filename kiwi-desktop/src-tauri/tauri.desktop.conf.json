{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kiwi-desktop",
  "version": "0.1.0",
  "identifier": "com.kiwi.mainboard",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://127.0.0.1:8080/dashboard.html?src=5001",
    "beforeBuildCommand": "",
    "frontendDist": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "kiwi-desktop",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "../../target/release/plotly-client"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}




