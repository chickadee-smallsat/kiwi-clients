{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kiwi Dashboard",
  "version": "0.1.0",
  "identifier": "com.kiwi.mainboard",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://127.0.0.1:8080",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kiwi Dashboard",
        "url": "http://127.0.0.1:8080",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 650,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}




